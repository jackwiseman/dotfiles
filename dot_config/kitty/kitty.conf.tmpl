# Font
font_family      Monaco Nerd Font
font_size 14
macos_thicken_font 0

confirm_os_window_close 0

modify_font cell_height +19px
modify_font cell_width -1px
modify_font baseline -1px

# Gruvbox Dark colorscheme
foreground {{ .gruvbox.fg1 }}
background {{ .gruvbox.bg0 }}

color0  {{ .gruvbox.bg0 }}
color1  {{ .gruvbox.red }}
color2  {{ .gruvbox.green }}
color3  {{ .gruvbox.yellow }}
color4  {{ .gruvbox.blue }}
color5  {{ .gruvbox.purple }}
color6  {{ .gruvbox.aqua }}
color7  {{ .gruvbox.fg4 }}
color8  {{ .gruvbox.gray }}
color9  {{ .gruvbox.bright_red }}
color10 {{ .gruvbox.bright_green }}
color11 {{ .gruvbox.bright_yellow }}
color12 {{ .gruvbox.bright_blue }}
color13 {{ .gruvbox.bright_purple }}
color14 {{ .gruvbox.bright_aqua }}
color15 {{ .gruvbox.fg1 }}

# Window
hide_window_decorations titlebar-only
window_padding_width 0

# Selection
copy_on_select clipboard

# Shell — launch tmux on startup
shell zsh -l -c tmux

# Keep a block cursor at the prompt (don't let shell integration beam it),
# so non-tmux windows match the block cursor shown inside tmux
shell_integration no-cursor

# Disable all default keybindings — tmux/nvim handle everything
clear_all_shortcuts yes

# Custom keybindings
map cmd+c send_text all \uE000
map cmd+n send_text all \uE001
map cmd+p send_text all \uE002
map ctrl+g send_text all \uE005

# Font size
map cmd+equal change_font_size all +1.0
map cmd+minus change_font_size all -1.0

# Essential macOS shortcuts
map cmd+v paste_from_clipboard
map cmd+q quit
