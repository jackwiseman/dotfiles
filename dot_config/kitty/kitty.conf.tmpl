# Font
font_family      Monaco Nerd Font
bold_font        Monaco Nerd Font Bold
italic_font      Monaco Nerd Font Book Italic
bold_italic_font Monaco Nerd Font Bold Italic
{{- if eq .osid "linux-arch" }}
font_size 9.5
{{ else }}
font_size 14
{{- end }}

# Match Alacritty font offset (y=15) and glyph offset (y=7)
modify_font cell_height 15px
modify_font baseline 7

# Gruvbox Dark colorscheme
foreground #ebdbb2
background #282828

color0  #282828
color1  #cc241d
color2  #98971a
color3  #d79921
color4  #458588
color5  #b16286
color6  #689d6a
color7  #a89984
color8  #928374
color9  #fb4934
color10 #b8bb26
color11 #fabd2f
color12 #83a598
color13 #d3869b
color14 #8ec07c
color15 #ebdbb2

# Window
hide_window_decorations titlebar-only
window_padding_width 4

# Selection
copy_on_select clipboard

# Shell — launch tmux on startup
shell zsh -l -c tmux

# Disable all default keybindings — tmux/nvim handle everything
clear_all_shortcuts yes

# Custom keybindings
{{- if eq .keyboardLayout "win" }}
map alt+c send_text all \uE000
map alt+n send_text all \uE001
map alt+p send_text all \uE002
{{ else }}
map cmd+c send_text all \uE000
map cmd+n send_text all \uE001
map cmd+p send_text all \uE002
{{- end }}
map ctrl+g send_text all \uE005

# Font size
map cmd+equal change_font_size all +1.0
map cmd+minus change_font_size all -1.0

# Essential macOS shortcuts
map cmd+v paste_from_clipboard
map cmd+q quit
