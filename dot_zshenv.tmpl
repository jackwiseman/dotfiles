export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"

export ZDOTDIR="$XDG_CONFIG_HOME/zsh"
export ZIM_HOME="$XDG_DATA_HOME/zim"

export EDITOR="nvim"
export VISUAL="nvim"

export FZF_ALT_C_COMMAND="" # disable fzf's annoying alt-c bind

# keep zoxide out of $HOME and macOS temp dirs (tempe et al.)
export _ZO_EXCLUDE_DIRS="$HOME:/private/*:/var/folders/**"

export GOPATH=~/go
# export DISABLE_AUTO_TITLE=true
export TLDR_AUTO_UPDATE_DISABLED=true

{{ if eq .osid "darwin" }}
export HOMEBREW_NO_AUTO_UPDATE=1
export HOMEBREW_NO_ENV_HINTS=1

# cache xcrun -show-sdk-path (~50–150ms otherwise, every shell)
_sdk_cache="${XDG_DATA_HOME:-$HOME/.local/share}/zsh/sdk-path"
[[ -s "$_sdk_cache" ]] || { mkdir -p "${_sdk_cache:h}" && xcrun -show-sdk-path > "$_sdk_cache"; }
export CPPFLAGS="-I$(<"$_sdk_cache")/usr/include"
unset _sdk_cache

{{ if ne .profile "minimal" -}}
# use 1password for ssh
export SSH_AUTH_SOCK=~/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock
{{- end }}
{{- end }}

{{ if and (eq .chezmoi.os "linux") (not .headless) }}
export WLR_NO_HARDWARE_CURSORS=1
{{- end }}
